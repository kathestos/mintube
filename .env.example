# Copy to .env.local and fill in values.
# https://console.cloud.google.com/apis/library/youtube.googleapis.com — enable YouTube Data API v3
# https://console.cloud.google.com/apis/credentials — OAuth 2.0 Client ID (Web application)
#
# Local Google OAuth redirect URI:
#   http://localhost:3000/api/auth/callback/google
# Production (Vercel): also add in Google Cloud → Credentials → your Web client:
#   Authorized JavaScript origins: https://YOUR_PROJECT.vercel.app
#   Authorized redirect URIs:       https://YOUR_PROJECT.vercel.app/api/auth/callback/google
# (Add your custom domain too if you use one.)
#
# Vercel → Project → Settings → Environment Variables (Production):
#   NEXTAUTH_SECRET, GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET — same as local (or new secret for prod).
#   NEXTAUTH_URL — optional: set to https://YOUR_PROJECT.vercel.app or your custom domain.
#     If omitted, the app infers https://$VERCEL_URL on Vercel builds.

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
